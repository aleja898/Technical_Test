@page "/users"
@page "/users/list"
@inject UserService UserService
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime

<PageTitle>Usuarios</PageTitle>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>👥 Gestión de Usuarios</h2>
        <button class="btn btn-primary" @onclick="ShowCreateForm">
            <i class="bi bi-plus-circle"></i> Nuevo Usuario
        </button>
    </div>

    @if (_loading)
    {
        <div class="text-center">
            <div class="spinner-border" role="status">
                <span class="visually-hidden">Cargando...</span>
            </div>
        </div>
    }
    else if (_users.Count == 0)
    {
        <div class="alert alert-info text-center">
            No hay usuarios registrados.
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>ID</th>
                        <th>Nombre</th>
                        <th>Apellidos</th>
                        <th>Email</th>
                        <th>Dirección</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in _users)
                    {
                        <tr>
                            <td>@user.Id</td>
                            <td>@user.Nombre</td>
                            <td>@user.Apellidos</td>
                            <td>@user.Mail</td>
                            <td>@user.Direccion</td>
                            <td>
                                <button class="btn btn-sm btn-info me-2" @onclick="() => ViewUserDetails(user.Id)">
                                    Detalles
                                </button>
                                <button class="btn btn-sm btn-warning me-2" @onclick="() => EditUser(user)">
                                    Editar
                                </button>
                                <button class="btn btn-sm btn-danger" @onclick="() => DeleteUser(user.Id)">
                                    Eliminar
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>


<div class="modal fade @(showModal ? "show d-block" : "")" tabindex="-1" style="@(showModal ? "background-color: rgba(0,0,0,0.5);" : "")">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">@(_editingUser != null ? "Editar Usuario" : "Nuevo Usuario")</h5>
                <button type="button" class="btn-close" @onclick="HideModal"></button>
            </div>
            <div class="modal-body">
                <EditForm Model="@_formData" OnValidSubmit="SaveUser" OnInvalidSubmit="HandleInvalidSubmit">
                    <DataAnnotationsValidator />
                    <ValidationSummary />
                    
                    <div class="mb-3">
                        <label class="form-label">Nombre:</label>
                        <InputText class="form-control" @bind-Value="_formData.Nombre" />
                        <ValidationMessage For="@(() => _formData.Nombre)" />
                    </div>
                    
                    <div class="mb-3">
                        <label class="form-label">Apellidos:</label>
                        <InputText class="form-control" @bind-Value="_formData.Apellidos" />
                        <ValidationMessage For="@(() => _formData.Apellidos)" />
                    </div>
                    
                    <div class="mb-3">
                        <label class="form-label">Email:</label>
                        <InputText class="form-control" @bind-Value="_formData.Mail" />
                        <ValidationMessage For="@(() => _formData.Mail)" />
                    </div>
                    
                    <div class="mb-3">
                        <label class="form-label">Dirección:</label>
                        <InputText class="form-control" @bind-Value="_formData.Direccion" />
                        <ValidationMessage For="@(() => _formData.Direccion)" />
                    </div>
                    
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" @onclick="HideModal">Cancelar</button>
                        <button type="submit" class="btn btn-primary">Guardar</button>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter]
    [SupplyParameterFromQuery]
    public int? editId { get; set; }

    private List<UserDto> _users = new();
    private bool _loading = true;
    private bool showModal = false;
    private UserDto? _editingUser;
    private CreateUserRequest _formData = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadUsers();
    }

    protected override async Task OnParametersSetAsync()
    {
        if (editId.HasValue)
        {
            await LoadUsers();
            var userToEdit = _users.FirstOrDefault(u => u.Id == editId.Value);
            if (userToEdit != null)
            {
                EditUser(userToEdit);
            }
        }
    }

    private async Task LoadUsers()
    {
        _loading = true;
        _users = await UserService.GetUsersAsync();
        _loading = false;
    }

    private void ShowCreateForm()
    {
        Console.WriteLine("ShowCreateForm llamado");
        _editingUser = null;
        _formData = new CreateUserRequest();
        Console.WriteLine($"_formData inicializado: {_formData.Nombre}, {_formData.Mail}");
        showModal = true;
    }

    private void EditUser(UserDto user)
    {
        _editingUser = user;
        _formData = new CreateUserRequest
        {
            Nombre = user.Nombre,
            Apellidos = user.Apellidos,
            Direccion = user.Direccion,
            Mail = user.Mail
        };
        showModal = true;
    }

    private async Task SaveUser()
    {
        bool success;
        if (_editingUser != null)
        {
            var updateRequest = new UpdateUserRequest
            {
                Nombre = _formData.Nombre,
                Apellidos = _formData.Apellidos,
                Direccion = _formData.Direccion,
                Mail = _formData.Mail
            };
            success = await UserService.UpdateUserAsync(_editingUser.Id, updateRequest);
        }
        else
        {
            success = await UserService.CreateUserAsync(_formData);
        }

        if (success)
        {
            HideModal();
            await LoadUsers();
        }
    }

    private void HandleInvalidSubmit()
    {
    }

    private async Task DeleteUser(int id)
    {
        bool confirmed = await JSRuntime.InvokeAsync<bool>("confirm", "¿Está seguro de eliminar este usuario?");
        if (confirmed)
        {
            await UserService.DeleteUserAsync(id);
            await LoadUsers();
        }
    }

    private void ViewUserDetails(int id)
    {
        NavigationManager.NavigateTo($"/users/userdetails/{id}");
    }

    private void HideModal()
    {
        showModal = false;
        _editingUser = null;
        _formData = new CreateUserRequest();
    }
}
