@page "/users/userdetails/{Id}"
@inject UserService UserService
@inject NavigationManager NavigationManager

<PageTitle>User Details</PageTitle>

<div class="container mt-4">
    @if (user != null)
    {
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h3 class="mb-0">Detalles del Usuario</h3>
                <div>
                    <button class="btn btn-warning me-2" @onclick="EditUser">
                        <i class="fas fa-edit"></i> Editar
                    </button>
                    <button class="btn btn-secondary" @onclick="GoBack">
                        <i class="fas fa-arrow-left"></i> Volver
                    </button>
                </div>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-6">
                        <h5 class="text-primary">Información Personal</h5>
                        <table class="table table-borderless">
                            <tr>
                                <td><strong>ID:</strong></td>
                                <td>@user.Id</td>
                            </tr>
                            <tr>
                                <td><strong>Nombre:</strong></td>
                                <td>@user.Nombre</td>
                            </tr>
                            <tr>
                                <td><strong>Apellidos:</strong></td>
                                <td>@user.Apellidos</td>
                            </tr>
                            <tr>
                                <td><strong>Email:</strong></td>
                                <td>@user.Mail</td>
                            </tr>
                            <tr>
                                <td><strong>Dirección:</strong></td>
                                <td>@user.Direccion</td>
                            </tr>
                        </table>
                    </div>
                    <div class="col-md-6">
                        <h5 class="text-primary">Reservas del Usuario</h5>
                        @if (userReservations != null && userReservations.Any())
                        {
                            <div class="table-responsive">
                                <table class="table table-sm">
                                    <thead>
                                        <tr>
                                            <th>ID</th>
                                            <th>Hotel</th>
                                            <th>Habitación</th>
                                            <th>Entrada</th>
                                            <th>Salida</th>
                                            <th>Estado</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var reservation in userReservations)
                                        {
                                            <tr>
                                                <td>@reservation.Id</td>
                                                <td>@reservation.NombreHotel</td>
                                                <td>@reservation.IdHabitacion</td>
                                                <td>@reservation.FechaEntrada.ToString("dd/MM/yyyy")</td>
                                                <td>@(reservation.FechaSalida?.ToString("dd/MM/yyyy") ?? "Sin definir")</td>
                                                <td>
                                                    <span class="badge @(reservation.Estado == 1 ? "bg-success" : "bg-danger")">
                                                        @(reservation.Estado == 1 ? "Reservado" : "Cancelado")
                                                    </span>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                        else
                        {
                            <p class="text-muted">Este usuario no tiene reservas registradas.</p>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
    else if (loading)
    {
        <div class="text-center">
            <div class="spinner-border" role="status">
                <span class="visually-hidden">Cargando...</span>
            </div>
            <p class="mt-2">Cargando detalles del usuario...</p>
        </div>
    }
    else
    {
        <div class="alert alert-warning">
            <h4>Usuario no encontrado</h4>
            <p>El usuario que buscas no existe o ha sido eliminado.</p>
            <button class="btn btn-primary" @onclick="GoBack">Volver a la lista</button>
        </div>
    }
</div>

@code {
    [Parameter]
    public string Id { get; set; }

    private UserDto user = null;
    private List<ReservationDto> userReservations = new List<ReservationDto>();
    private bool loading = true;

    protected override async Task OnParametersSetAsync()
    {
        await LoadUserDetails();
    }

    private async Task LoadUserDetails()
    {
        loading = true;
        
        try
        {
            if (int.TryParse(Id, out int userId))
            {
                user = await UserService.GetUserByIdAsync(userId);
                if (user != null)
                {
                    // Cargar las reservas del usuario
                    userReservations = (await UserService.GetUserReservationsAsync(userId)).ToList();
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading user details: {ex.Message}");
        }
        finally
        {
            loading = false;
        }
    }

    private void EditUser()
    {
        NavigationManager.NavigateTo($"/users?editId={user.Id}");
    }

    private void GoBack()
    {
        NavigationManager.NavigateTo("/users");
    }
}
